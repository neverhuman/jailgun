# Template for scripts/run-live-7tab.sh. Copy to .env.live-7tab and fill in.
# .env.live-7tab is gitignored. Do not commit secrets, tokens, or real hostnames.
#
# Prerequisite paths the runner also checks:
#   - $JAILGUN_PROMPT_FILE             must exist + be non-empty
#   - dirname($JAILGUN_JMCP_INBOX_DIR) must exist (the JMCP repo dir)
#   - $JAILGUN_SOURCE_REPO_URL/.git    must be a real git checkout
#   - SSH access to $JAILGUN_REMOTE_HOST with clean $JAILGUN_REMOTE_DIR
#
# Telegram bot credentials are NOT stored here anymore. They live with the
# JMCP bridge (see ~/code/jmcp/.env in the JMCP repo). Jailgun only writes
# JPCM/2.0 envelopes; the bridge handles delivery.

# --- Run shape -------------------------------------------------------------
JAILGUN_TABS=7
JAILGUN_LOOPS=0
# JAILGUN_RUN_ID=                         # optional, defaults to live-7tab-<utc-timestamp>

# --- ChatGPT / CDP ---------------------------------------------------------
# Legacy single-CDP value used by scripts/run-live-7tab.sh. The two-profile
# production wrapper ignores/unsets this for chrome-bridge and uses
# JAILGUN_CDP_PORT_START instead.
JAILGUN_CDP_URL=http://127.0.0.1:9222

# Two-profile production wrapper: scripts/run-live-2profile.sh
JAILGUN_PROFILE_A_DIR=$HOME/.jailgun/profiles/prod-google-a
JAILGUN_PROFILE_B_DIR=$HOME/.jailgun/profiles/prod-google-b
JAILGUN_CDP_PORT_START=9224
# JAILGUN_CHROME_STATE_DIR=              # optional; leave unset for per-run state
# Point this at a real filled prompt file in prompts/local/ before running.
JAILGUN_PROMPT_FILE=prompts/local/live-7tab.txt
# Colon-separated list of Chrome profile directories for multi-user round-robin.
# Each profile should be logged into a different Google/ChatGPT account.
# Tabs round-robin across profiles: tab 1 → user-a, tab 2 → user-b, tab 3 → user-a, etc.
# JAILGUN_CHROME_PROFILE_POOL=~/.google-profile-user-a:~/.google-profile-user-b

# --- Source repo to tar + push --------------------------------------------
JAILGUN_SOURCE_REPO_URL=/absolute/path/to/source/checkout
JAILGUN_SOURCE_REF=HEAD

# --- Remote deploy target --------------------------------------------------
JAILGUN_REMOTE_HOST=user@remote.example
JAILGUN_REMOTE_DIR=/srv/jailgun-target
JAILGUN_REMOTE_COMMAND="bash scripts/ci-fast-push.sh"
JAILGUN_EXPECTED_TOP_LEVEL=source-top-level-dir
JAILGUN_TAR_TARGET_NAME=source-top-level-dir.tar.gz

# --- Dashboard -------------------------------------------------------------
JAILGUN_DASHBOARD_ADDR=127.0.0.1:8787
JAILGUN_DASHBOARD_HOLD_SECONDS=30
JAILGUN_DASHBOARD_START_TIMEOUT_SECONDS=300

# --- Cargo + retry budgets -------------------------------------------------
JAILGUN_CARGO_JOBS=10
JAILGUN_MAX_DOWNLOAD_START_LATENCY_MS=10000
JAILGUN_MESSAGE_STREAM_RETRY_LIMIT=6
JAILGUN_MESSAGE_STREAM_RETRY_DELAY_MS=10000

# --- JMCP notify (required by run_preflight) -------------------------------
JAILGUN_NOTIFY_JMCP=1
JAILGUN_JMCP_INBOX_DIR=~/code/jmcp/inbox

# --- GitHub CI gate (optional, set JAILGUN_CI=1 to enable) -----------------
JAILGUN_CI=0
# JAILGUN_CI_REPO=owner/repo               # required when JAILGUN_CI=1
JAILGUN_CI_BRANCH=main
JAILGUN_CI_MAX_ATTEMPTS=60
JAILGUN_CI_POLL_SECONDS=20

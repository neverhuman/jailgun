#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

inbox_dir="${JAILGUN_JMCP_INBOX_DIR:-$HOME/code/jmcp/inbox}"
# Resolve a leading tilde the cargo CLI also understands, in case the env
# value came from a shell that did not expand it.
case "$inbox_dir" in
  "~"|"~/"*) inbox_dir="${HOME}${inbox_dir#~}" ;;
esac

# Skip silently when the JMCP inbox isn't available — e.g. on a fresh
# checkout before the user has cloned the JMCP repo. The user can still see
# the commit elsewhere; we just don't queue a notification.
parent_dir="$(dirname "$inbox_dir")"
if [[ ! -d "$parent_dir" ]]; then
  exit 0
fi

cargo run -q -p jailgun-cli -- notify-commit \
  --jmcp-inbox-dir "$inbox_dir" \
  --repo "$repo_root" \
  --revision HEAD >/dev/null
